# ── Strava ──────────────────────────────────────────────────────────────────
STRAVA_CLIENT_ID=your_client_id
STRAVA_CLIENT_SECRET=your_client_secret
STRAVA_WEBHOOK_VERIFY_TOKEN=some-random-secret-string

# ── Deployment ───────────────────────────────────────────────────────────────
PUBLIC_URL=https://api.irlll.com
PORT=8080  # Production (Cloud Run / gunicorn). For local dev, override with e.g. PORT=8000 or just use `make dev` which passes --port 8000 directly.
SECRET_KEY=another-random-secret

# ── Twilio ───────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+15551234567

# ── Physics defaults ─────────────────────────────────────────────────────────
CRR=0.004
RHO=1.225

# ── Garmin Connect ────────────────────────────────────────────────────────────
GARMIN_CONSUMER_KEY=your_garmin_consumer_key
GARMIN_CONSUMER_SECRET=your_garmin_consumer_secret

# ── TrainingPeaks ─────────────────────────────────────────────────────────────
TP_CLIENT_ID=your_tp_client_id
TP_CLIENT_SECRET=your_tp_client_secret

# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Google OAuth (for /admin dashboard) ──────────────────────────────────────
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Access control ───────────────────────────────────────────────────────────
ALLOWED_PHONES=+16035317244

# ── GCP (set automatically on Cloud Run via ADC, only needed for local dev) ──
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
