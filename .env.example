# ── Strava ──────────────────────────────────────────────────────────────────
# Create a Strava app at https://www.strava.com/settings/api
STRAVA_CLIENT_ID=your_client_id
STRAVA_CLIENT_SECRET=your_client_secret
# Make up any random string — used to verify webhook ownership
STRAVA_WEBHOOK_VERIFY_TOKEN=some-random-secret-string

# ── Deployment ───────────────────────────────────────────────────────────────
# Public URL of your deployed app (no trailing slash)
PUBLIC_URL=https://your-app.up.railway.app
PORT=8000
SECRET_KEY=another-random-secret

# ── Twilio ───────────────────────────────────────────────────────────────────
# Sign up at https://www.twilio.com — free trial includes ~$15 credit
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+15551234567   # your Twilio number
TWILIO_TO_NUMBER=+15559876543     # your personal number

# ── Rider constants ──────────────────────────────────────────────────────────
RIDER_MASS_KG=75.0     # combined rider + bike mass in kg
CRR=0.004              # rolling resistance (road: 0.003-0.005, gravel: 0.006-0.010)
RHO=1.225              # air density kg/m³ (sea level 15°C default)
                       # lower at altitude: ~1.18 at 500m, ~1.11 at 1500m

# ── Token storage ────────────────────────────────────────────────────────────
# Path to the file where OAuth tokens are saved
# On Railway: mount a persistent volume at /data and set TOKEN_PATH=/data/tokens.json
TOKEN_PATH=tokens.json
