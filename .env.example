# ── Strava ──────────────────────────────────────────────────────────────────
STRAVA_CLIENT_ID=your_client_id
STRAVA_CLIENT_SECRET=your_client_secret
STRAVA_WEBHOOK_VERIFY_TOKEN=some-random-secret-string

# ── Deployment ───────────────────────────────────────────────────────────────
PUBLIC_URL=https://your-app.up.railway.app
PORT=8000
SECRET_KEY=another-random-secret

# ── Twilio ───────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+15551234567

# ── Physics defaults (per-user weight is stored in DB, these are global) ─────
CRR=0.004
RHO=1.225

# ── Database ─────────────────────────────────────────────────────────────────
# On Railway: mount a persistent volume at /data and set DB_PATH=/data/strava_cda.db
DB_PATH=strava_cda.db
