{
  "hosting": {
    "public": "public",
    "ignore": ["firebase.json", "**/.*"],
    "rewrites": [
      {
        "source": "/chat**",
        "run": {
          "serviceId": "coach-claude",
          "region": "us-east1"
        }
      },
      {
        "source": "/auth**",
        "run": {
          "serviceId": "coach-claude",
          "region": "us-east1"
        }
      },
      {
        "source": "/callback**",
        "run": {
          "serviceId": "coach-claude",
          "region": "us-east1"
        }
      },
      {
        "source": "/privacy-policy",
        "run": { "serviceId": "coach-claude", "region": "us-east1" }
      },
      {
        "source": "/privacy",
        "run": { "serviceId": "coach-claude", "region": "us-east1" }
      },
      {
        "source": "/terms-and-conditions",
        "run": { "serviceId": "coach-claude", "region": "us-east1" }
      },
      { "source": "**", "destination": "/index.html" }
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
          { "key": "X-Content-Type-Options", "value": "nosniff" }
        ]
      }
    ]
  }
}
